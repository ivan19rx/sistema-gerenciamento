// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum TipoLancamento {
  ENTRADA
  SAIDA
}

model FornecedorCliente {
  id           Int          @id @default(autoincrement())
  nome         String       @unique
  saldo        Decimal      @default(0) @db.Decimal(10, 2)
  ativo        Boolean      @default(true)
  lancamentos  Lancamento[]
  criadoEm     DateTime     @default(now()) @map("criado_em")
  atualizadoEm DateTime     @updatedAt @map("atualizado_em")

  @@map("fornecedores_clientes")
}

model Conta {
  id          Int          @id @default(autoincrement())
  nome        String       @unique
  lancamentos Lancamento[]

  @@map("contas")
}

model Categoria {
  id          Int          @id @default(autoincrement())
  nome        String       @unique
  lancamentos Lancamento[]

  @@map("categorias")
}

model Lancamento {
  id                  Int                @id @default(autoincrement())
  dataLancamento      DateTime           @map("data_lancamento")
  tipo                TipoLancamento
  valor               Decimal            @db.Decimal(10, 2)
  classificacao       String?
  observacao          String?            @db.Text

  fornecedorClienteId Int                @map("fornecedor_cliente_id")
  contaId             Int?               @map("conta_id")
  categoriaId         Int?               @map("categoria_id")

  fornecedorCliente   FornecedorCliente  @relation(fields: [fornecedorClienteId], references: [id])
  conta               Conta?             @relation(fields: [contaId], references: [id])
  categoria           Categoria?         @relation(fields: [categoriaId], references: [id])

  criadoEm            DateTime           @default(now()) @map("criado_em")
  atualizadoEm        DateTime           @updatedAt @map("atualizado_em")

  @@map("lancamentos")
}

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum TipoLancamento {
  ENTRADA
  SAIDA
}

// Administrador global do sistema. Cadastra empresas e tem acesso total
// (pode operar os dados de qualquer empresa informando a empresa-alvo).
model Admin {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  senha        String
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  @@map("admins")
}

// Tenant do sistema. Cada empresa possui seus próprios dados isolados.
model Empresa {
  id                 Int      @id @default(autoincrement())
  cnpj               String   @unique
  razaoSocial        String   @map("razao_social")
  nomeFantasia       String?  @map("nome_fantasia")
  inscricaoEstadual  String?  @map("inscricao_estadual")
  inscricaoMunicipal String?  @map("inscricao_municipal")
  endereco           String?
  email              String   @unique
  senha              String
  ativo              Boolean  @default(true)
  criadoEm           DateTime @default(now()) @map("criado_em")
  atualizadoEm       DateTime @updatedAt @map("atualizado_em")

  fornecedoresClientes FornecedorCliente[]
  contas               Conta[]
  categorias           Categoria[]
  lancamentos          Lancamento[]

  @@map("empresas")
}

model FornecedorCliente {
  id           Int          @id @default(autoincrement())
  nome         String
  saldo        Decimal      @default(0) @db.Decimal(10, 2)
  ativo        Boolean      @default(true)
  empresaId    Int          @map("empresa_id")
  empresa      Empresa      @relation(fields: [empresaId], references: [id])
  lancamentos  Lancamento[]
  criadoEm     DateTime     @default(now()) @map("criado_em")
  atualizadoEm DateTime     @updatedAt @map("atualizado_em")

  // nome único por empresa (não globalmente)
  @@unique([empresaId, nome])
  @@map("fornecedores_clientes")
}

model Conta {
  id          Int          @id @default(autoincrement())
  nome        String
  empresaId   Int          @map("empresa_id")
  empresa     Empresa      @relation(fields: [empresaId], references: [id])
  lancamentos Lancamento[]

  @@unique([empresaId, nome])
  @@map("contas")
}

model Categoria {
  id          Int          @id @default(autoincrement())
  nome        String
  empresaId   Int          @map("empresa_id")
  empresa     Empresa      @relation(fields: [empresaId], references: [id])
  lancamentos Lancamento[]

  @@unique([empresaId, nome])
  @@map("categorias")
}

model Lancamento {
  id                  Int                @id @default(autoincrement())
  dataLancamento      DateTime           @map("data_lancamento")
  tipo                TipoLancamento
  valor               Decimal            @db.Decimal(10, 2)
  classificacao       String?
  observacao          String?            @db.Text

  empresaId           Int                @map("empresa_id")
  fornecedorClienteId Int                @map("fornecedor_cliente_id")
  contaId             Int                @map("conta_id")
  categoriaId         Int                @map("categoria_id")

  empresa             Empresa            @relation(fields: [empresaId], references: [id])
  fornecedorCliente   FornecedorCliente  @relation(fields: [fornecedorClienteId], references: [id])
  conta               Conta              @relation(fields: [contaId], references: [id])
  categoria           Categoria          @relation(fields: [categoriaId], references: [id])

  criadoEm            DateTime           @default(now()) @map("criado_em")
  atualizadoEm        DateTime           @updatedAt @map("atualizado_em")

  @@index([empresaId, dataLancamento])
  @@map("lancamentos")
}
